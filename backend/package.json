    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "mammoth": "^1.7.1",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
